generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.pnpm/@prisma+client@6.19.3_prism_1d040ab5215f59f0e27ddee7f0cf082e/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organisation {
  id             String   @id @default(cuid())
  clerkOrgId     String   @unique
  name           String
  slug           String   @unique
  logoUrl        String?
  brandColor     String?  @default("#006D6B")
  documentHeader String?
  documentFooter String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  subscriptionStatus   SubscriptionStatus @default(FREE)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?

  apiKey               String?  @unique
  onboardingCompleted  Boolean  @default(false)

  uiTheme         String?  @default("light")
  uiPrimaryColor  String?  @default("#006D6B")
  uiLanguage      String?  @default("en")
  uiCurrency      String?  @default("EUR")
  uiDateFormat    String?  @default("DD/MM/YYYY")
  uiDefaultRole   String?  @default("PMO")
  uiCompactMode   Boolean? @default(false)

  slackTeamId     String?
  slackBotToken   String?
  gmailEmail      String?
  gmailWatchId    String?
  teamsWebhookUrl String?
  zoomAccountId   String?

  members         Member[]
  projects        Project[]
  invitations     Invitation[]
  resources       Resource[]
  departments     Department[]
  ambientMessages AmbientMessage[]

  @@map("organisations")
}

enum SubscriptionStatus {
  FREE
  PRO
  BUSINESS
  CANCELLED
  PAST_DUE
}

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  name          String?
  avatarUrl     String?
  preferredView String? // "PMO"|"CEO"|"STK"|"DEV"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships       Member[]
  activities        Activity[]
  requestedProjects Project[]

  @@map("users")
}

model Member {
  id       String   @id @default(cuid())
  role     Role     @default(VIEWER)
  joinedAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@unique([userId, organisationId])
  @@map("members")
}

enum Role {
  ADMIN
  MANAGER
  VIEWER
}

model Invitation {
  id        String       @id @default(cuid())
  email     String
  role      Role         @default(VIEWER)
  token     String       @unique @default(cuid())
  status    InviteStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime     @default(now())

  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Project {
  id              String          @id @default(cuid())
  name            String
  description     String?         @db.Text
  briefText       String?         @db.Text
  startDate       DateTime
  endDate         DateTime
  endDateForecast DateTime?
  status          ProjectStatus   @default(ACTIVE)
  shareToken      String?         @unique
  shareEnabled    Boolean         @default(false)
  category        String?
  guardianReport  GuardianReport?

  budgetTotal     Float @default(0)
  costActual      Float @default(0)
  revenueExpected Float @default(0)
  healthScore     Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  requestedById String?
  requestedBy   User?   @relation(fields: [requestedById], references: [id], onDelete: SetNull)

  phases             Phase[]
  sprints            Sprint[]
  activities         Activity[]
  risks              Risk[]
  statusLogs         ProjectStatusLog[]
  assignments        ResourceAssignment[]
  dependsOn          ProjectDependency[]  @relation("dependent")
  blockedBy          ProjectDependency[]  @relation("blocker")
  departments        ProjectDepartment[]
  alerts             Alert[]
  snapshots          ProjectSnapshot[]
  messages           ProjectMessage[]
  functionalAnalysis FunctionalAnalysis?
  documents          ProjectDocument[]
  ambientMessages    AmbientMessage[]

  @@index([organisationId])
  @@index([organisationId, status])
  @@index([updatedAt])
  @@map("projects")
}

enum ProjectStatus {
  NOT_STARTED
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
  CLOSED
}

model ProjectDependency {
  id          String  @id @default(cuid())
  projectId   String
  dependsOnId String
  project     Project @relation("dependent", fields: [projectId], references: [id], onDelete: Cascade)
  dependsOn   Project @relation("blocker", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([projectId, dependsOnId])
  @@map("project_dependencies")
}

model ProjectDepartment {
  id           String     @id @default(cuid())
  projectId    String
  departmentId String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([projectId, departmentId])
  @@map("project_departments")
}

model Resource {
  id            String   @id @default(cuid())
  name          String
  role          String
  costPerHour   Float    @default(0)
  capacityHours Float    @default(160)
  createdAt     DateTime @default(now())

  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  assignments      ResourceAssignment[]
  departmentId     String?
  department       Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignedFeatures Feature[]

  @@map("resources")
}

model Department {
  id        String   @id @default(cuid())
  name      String
  budget    Float    @default(0)
  color     String   @default("#007A73")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  resources Resource[]
  projects  ProjectDepartment[]

  @@unique([name, organisationId])
  @@map("departments")
}

model ResourceAssignment {
  id             String   @id @default(cuid())
  estimatedHours Float    @default(0)
  actualHours    Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([projectId, resourceId])
  @@map("resource_assignments")
}

model Risk {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  probability Int        @default(3)
  impact      Int        @default(3)
  status      RiskStatus @default(OPEN)
  mitigation  String?    @db.Text
  ownerId     String?
  ownerName   String?
  category    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, status])
  @@map("risks")
}

enum RiskStatus {
  OPEN
  MITIGATED
  CLOSED
}

model Phase {
  id     String  @id @default(cuid())
  num    Int
  label  String
  sub    String?
  accent String  @default("#007A73")
  order  Int     @default(0)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sprints Sprint[]

  @@map("phases")
}

model Sprint {
  id        String       @id @default(cuid())
  num       String
  name      String
  goal      String?      @db.Text
  startDate DateTime?
  endDate   DateTime?
  status    SprintStatus @default(UPCOMING)
  order     Int          @default(0)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  phaseId String?
  phase   Phase?  @relation(fields: [phaseId], references: [id], onDelete: SetNull)

  features Feature[]

  @@index([projectId])
  @@index([projectId, status])
  @@map("sprints")
}

enum SprintStatus {
  UPCOMING
  ACTIVE
  DONE
}

model Feature {
  id             String        @id @default(cuid())
  title          String
  module         String?
  status         FeatureStatus @default(TODO)
  priority       Priority      @default(MEDIUM)
  order          Int           @default(0)
  notes          String?       @db.Text
  estimatedHours Float         @default(0)
  actualHours    Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  sprintId String
  sprint   Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  dependsOn    FeatureDependency[] @relation("dependant")
  blockedBy    FeatureDependency[] @relation("blocker")
  assignedToId String?
  assignedTo   Resource?           @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([sprintId])
  @@index([sprintId, status])
  @@map("features")
}

model FeatureDependency {
  id          String  @id @default(cuid())
  featureId   String
  dependsOnId String
  feature     Feature @relation("dependant", fields: [featureId], references: [id], onDelete: Cascade)
  blocker     Feature @relation("blocker", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([featureId, dependsOnId])
  @@map("feature_dependencies")
}

enum FeatureStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

model Activity {
  id             String   @id @default(cuid())
  action         String
  entity         String?
  entityId       String?
  entityName     String?
  meta           Json?
  createdAt      DateTime @default(now())
  userId         String?
  userName       String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organisationId String?

  @@index([organisationId])
  @@index([organisationId, createdAt])
  @@index([projectId])
  @@map("activities")
}

model ProjectStatusLog {
  id          String        @id @default(cuid())
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status      ProjectStatus
  note        String?
  changedById String?
  changedBy   String?
  createdAt   DateTime      @default(now())
}

model GuardianReport {
  id             String   @id @default(cuid())
  projectId      String   @unique
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  healthScore    Int      @default(0)
  healthStatus   String   @default("UNKNOWN")
  insight        String   @default("")
  recommendation String   @default("")
  riskFlag       Boolean  @default(false)
  confidence     Float    @default(0)
  alertCount     Int      @default(0)
  generatedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("guardian_reports")
}

model Alert {
  id                 String    @id @default(cuid())
  organisationId     String
  projectId          String?
  project            Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type               String // "overdue", "spi_critical", "at_risk", "budget_critical", "blocked", "status_change", "milestone"
  level              String // "critical", "warning", "info"
  title              String
  detail             String
  action             String?
  read               Boolean   @default(false)
  resolved           Boolean   @default(false)
  emailSent          Boolean   @default(false)
  requiresValidation Boolean   @default(false)
  validatedBy        String?
  validatedAt        DateTime?
  createdAt          DateTime  @default(now())

  @@index([organisationId])
  @@index([projectId])
  @@index([createdAt])
  @@map("alerts")
}

model ProjectSnapshot {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version     Int
  name        String
  description String?
  data        Json // full project state (sprints, features, phases)
  reason      String? // why snapshot was taken
  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@map("project_snapshots")
}

// ── Domain Events ─────────────────────────────────────────────────────────
// Immutable append-only event store. Never updated, never deleted.
model DomainEvent {
  id             String   @id @default(cuid())
  type           String // e.g. "feature.status_changed", "sprint.completed", "risk.opened"
  aggregateType  String // "project" | "sprint" | "feature" | "risk"
  aggregateId    String // the entity ID
  organisationId String
  projectId      String?
  actorId        String? // user who triggered the event
  actorName      String?
  payload        Json // full event payload (before + after state where relevant)
  occurredAt     DateTime @default(now())

  outboxEvent OutboxEvent?

  @@index([organisationId])
  @@index([aggregateId])
  @@index([organisationId, occurredAt])
  @@map("domain_events")
}

// ── Transactional Outbox ──────────────────────────────────────────────────
// Written in the same DB transaction as the domain event.
// Worker polls for unprocessed rows and enqueues BullMQ jobs.
model OutboxEvent {
  id            String      @id @default(cuid())
  domainEventId String      @unique
  domainEvent   DomainEvent @relation(fields: [domainEventId], references: [id], onDelete: Cascade)
  queue         String // target BullMQ queue name
  jobName       String // BullMQ job name
  payload       Json // job data (may differ from domain event payload)
  processedAt   DateTime? // null = pending
  attempts      Int         @default(0)
  lastError     String?
  createdAt     DateTime    @default(now())

  @@index([processedAt])
  @@index([createdAt])
  @@map("outbox_events")
}

// ── Functional Analysis ───────────────────────────────────────────────────
model FunctionalAnalysis {
  id              String    @id @default(cuid())
  projectId       String    @unique
  content         Json
  status          FAStatus  @default(DRAFT)
  version         Int       @default(1)
  approvedBy      String?
  approvedAt      DateTime?
  videoUrl        String?
  videoTranscript String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions FAVersion[]

  @@map("functional_analyses")
}

model FAVersion {
  id         String   @id @default(cuid())
  analysisId String
  version    Int
  content    Json
  changedBy  String
  changeNote String?
  createdAt  DateTime @default(now())

  analysis FunctionalAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@map("fa_versions")
}

enum FAStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

// ── Project Documents ──────────────────────────────────────────────────────
model ProjectDocument {
  id        String       @id @default(cuid())
  projectId String
  type      DocumentType
  title     String
  content   Json?
  fileUrl   String?
  fileSize  Int?
  mimeType  String?
  version   Int          @default(1)
  status    String       @default("DRAFT")
  createdBy String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_documents")
}

enum DocumentType {
  PROJECT_CHARTER
  FUNCTIONAL_ANALYSIS
  RISK_REGISTER
  RACI_MATRIX
  CLOSURE_REPORT
  MEETING_NOTES
  CUSTOM
}

// ── Project Chat ───────────────────────────────────────────────────────────
model ProjectMessage {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  userName  String
  content   String      @db.Text
  type      MessageType @default(TEXT)
  mentions  String[]
  replyToId String?
  editedAt  DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  replyTo ProjectMessage?  @relation("replies", fields: [replyToId], references: [id])
  replies ProjectMessage[] @relation("replies")

  @@index([projectId, createdAt])
  @@map("project_messages")
}

enum MessageType {
  TEXT
  SYSTEM
  COMMAND
}

// ── Ambient Intelligence ─────────────────────────────────────────────────────
model AmbientMessage {
  id          String   @id @default(cuid())
  orgId       String
  projectId   String?
  platform    String
  type        String
  content     String   @db.Text
  sender      String
  summary     String?
  confidence  Float?
  extractions Json?
  applied     Boolean  @default(false)
  createdAt   DateTime @default(now())

  orgIdRelation     Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectIdRelation Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([projectId])
  @@map("ambient_messages")
}
