{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "title": "RoadmapAI — Guardian & Worker",
  "uid": "roadmap-guardian",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Guardian Jobs (1h)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(roadmap_guardian_jobs_total[1h]))",
          "legendFormat": "total"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "green" }] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Guardian Failures (1h)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(roadmap_guardian_jobs_total{outcome=\"failure\"}[1h]))",
          "legendFormat": "failures"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Circuit Breaker",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "roadmap_circuit_breaker_open", "legendFormat": "open" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "mappings": [
          { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "OPEN", "color": "red" } } }
        ]
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "AI Cache Hit Rate (1h)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(roadmap_ai_cache_hits_total[1h])) / (sum(increase(roadmap_ai_calls_total[1h])) + sum(increase(roadmap_ai_cache_hits_total[1h])))",
          "legendFormat": "hit rate"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 0.3, "color": "yellow" },
              { "value": 0.6, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Estimated AI Spend (USD)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "roadmap_ai_cost_usd_total", "legendFormat": "total" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Guardian Job Duration (p50 / p95 / p99)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(roadmap_guardian_job_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(roadmap_guardian_job_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(roadmap_guardian_job_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "AI Call Duration (p50 / p95)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(roadmap_ai_call_duration_seconds_bucket[5m])) by (le, prompt_version))",
          "legendFormat": "p50 {{prompt_version}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(roadmap_ai_call_duration_seconds_bucket[5m])) by (le, prompt_version))",
          "legendFormat": "p95 {{prompt_version}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Outbox Events Dispatched / Failed",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(roadmap_outbox_events_total{outcome=\"success\"}[1m])) by (queue)",
          "legendFormat": "success: {{queue}}"
        },
        {
          "expr": "sum(rate(roadmap_outbox_events_total{outcome=\"failure\"}[1m])) by (queue)",
          "legendFormat": "failure: {{queue}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "HTTP Request Rate by Route",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(roadmap_http_requests_total[1m])) by (route, status)",
          "legendFormat": "{{route}} {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP Latency p95 by Route",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(roadmap_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "AI Tokens/min (Input + Output)",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(roadmap_ai_tokens_total{type=\"input\"}[1m])) * 60",
          "legendFormat": "input tokens/min"
        },
        {
          "expr": "sum(rate(roadmap_ai_tokens_total{type=\"output\"}[1m])) * 60",
          "legendFormat": "output tokens/min"
        }
      ]
    }
  ]
}
