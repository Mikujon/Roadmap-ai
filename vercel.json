{
  "installCommand": "pnpm install --frozen-lockfile --ignore-workspace",
  "buildCommand": "next build",
  "crons": [
    { "path": "/api/cron/daily", "schedule": "0 8 * * *" }
  ],
  "functions": {
    "src/app/api/stream/route.ts": { "maxDuration": 300 },
    "src/app/api/v1/ai/chat/route.ts": { "maxDuration": 60 },
    "src/app/api/mcp/ingest/route.ts": { "maxDuration": 60 }
  }
}
